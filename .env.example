# Copy to .env or .env.local. Used by root-level scripts (e.g. scripts/test-sdk.mjs) and optionally by workspaces that read from root.

# ─── Stellar Agent Kit (optional for script tests) ─────────────────────────
# Stellar secret key (S...). Optional for test-sdk.mjs (script uses test key if unset).
# SECRET_KEY=

# Required for DEX quotes/swaps in CLI, MCP, and UI. Get from https://soroswap.com
# SOROSWAP_API_KEY=

# ─── CLI agent (optional) ──────────────────────────────────────────────────
# Groq API key for interactive agent. Or pass --api-key when running the agent.
# GROQ_API_KEY=
